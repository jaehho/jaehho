#!/bin/bash
# Auto-detect the default route interface (works on native Linux and WSL)
IFACE=$(ip route show default 2>/dev/null | awk '/default/{print $5; exit}')
# Fallback: first non-loopback interface listed in /proc/net/dev
PROC_NET_DEV="${PROC_NET_DEV:-/proc/net/dev}"
[[ -z "$IFACE" ]] && IFACE=$(awk 'NR>2{gsub(/:$/,"",$1); if($1!="lo"){print $1; exit}}' "$PROC_NET_DEV")

R1=$(awk -v i="$IFACE:" '$1==i {print $2}' "$PROC_NET_DEV")
T1=$(awk -v i="$IFACE:" '$1==i {print $10}' "$PROC_NET_DEV")
sleep 1
R2=$(awk -v i="$IFACE:" '$1==i {print $2}' "$PROC_NET_DEV")
T2=$(awk -v i="$IFACE:" '$1==i {print $10}' "$PROC_NET_DEV")

printf "↓%d ↑%d KB/s" $(( (R2-R1)/1024 )) $(( (T2-T1)/1024 ))
