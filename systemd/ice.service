[Unit]
Description=SSHFS mount for Cooper ICE servers (ice00–ice11)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=/home/jaeho/jaehho/.env
ExecStart=/home/jaeho/jaehho/scripts/ice/mount.sh
ExecStop=/bin/fusermount -u /mnt/ice
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
