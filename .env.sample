# Local directory where the ICE AFS filesystem will be mounted (scripts/ice/mount.sh)
MOUNTPOINT=/mnt/ice

# Local Linux user that will own the mounted files (scripts/ice/mount.sh)
LOCAL_USER=jaeho

# ICE cluster SSH username (e.g. jaeho.cho)
ICE_USER=

# ICE cluster SSH password — used by rclone mount and ssh.exp for automated auth
ICE_PASSWORD=
