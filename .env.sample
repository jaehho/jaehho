# Local directory where the ICE AFS filesystem will be mounted (scripts/ice/mount-ice.sh)
MOUNTPOINT=/mnt/ice

# Absolute path on the remote AFS filesystem to mount (scripts/ice/mount-ice.sh)
REMOTE_PATH=/afs/ee.cooper.edu/user/j/jaeho.cho

# SSH username on the ICE cluster (scripts/ice/mount-ice.sh, ssh-ice.exp)
REMOTE_USER=jaeho.cho

# Local Linux user that will own the mounted files (scripts/ice/mount-ice.sh)
LOCAL_USER=jaeho

# ICE cluster SSH password — used by sshfs and ssh-ice.exp for automated auth
ICE_PASSWORD=
