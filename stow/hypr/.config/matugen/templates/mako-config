# Mako notification daemon — generated by matugen

# Appearance
font=JetBrainsMono Nerd Font 11
background-color={{colors.surface.default.hex}}E6
text-color={{colors.on_surface.default.hex}}
border-color={{colors.primary.default.hex}}CC
border-size=2
border-radius=12
width=380
padding=12
margin=10

# Behavior
default-timeout=5000
layer=overlay
anchor=top-right
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48

# Grouping
group-by=app-name

# Progress bar (volume/brightness OSD)
progress-color=source {{colors.primary.default.hex}}

# Do-not-disturb mode
[mode=do-not-disturb]
invisible=1

# Urgency overrides
[urgency=low]
border-color={{colors.tertiary_fixed.default.hex}}CC
default-timeout=3000

[urgency=normal]
border-color={{colors.primary.default.hex}}CC
default-timeout=5000

[urgency=high]
border-color={{colors.error.default.hex}}CC
default-timeout=0

# Persistent normal notification (blue border, no timeout)
# Usage: notify-send -c persistent "Title" "Body"
[category=persistent]
default-timeout=0
