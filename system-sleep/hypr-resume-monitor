#!/bin/bash
# Fix frozen external monitors after suspend (Nvidia + Hyprland)
# Dynamically enumerates all non-eDP monitors and power-cycles them.

case "$1" in
    post)
        sleep 2
        for uid_dir in /run/user/*/hypr; do
            [ -d "$uid_dir" ] || continue
            uid=$(echo "$uid_dir" | grep -oP '/run/user/\K[0-9]+')
            for instance_dir in "$uid_dir"/*/; do
                sig=$(basename "$instance_dir")
                export HYPRLAND_INSTANCE_SIGNATURE="$sig"
                export XDG_RUNTIME_DIR="/run/user/$uid"

                # Get all non-laptop monitors and their current config
                monitors=$(sudo -u "#$uid" \
                    HYPRLAND_INSTANCE_SIGNATURE="$sig" \
                    XDG_RUNTIME_DIR="/run/user/$uid" \
                    hyprctl monitors -j 2>/dev/null) || continue

                echo "$monitors" | jq -r '.[] | select(.name != "eDP-1") | "\(.name) \(.width)x\(.height)@\(.refreshRate | floor) \(.x)x\(.y) \(.scale)"' | \
                while read -r name res pos scale; do
                    sudo -u "#$uid" \
                        HYPRLAND_INSTANCE_SIGNATURE="$sig" \
                        XDG_RUNTIME_DIR="/run/user/$uid" \
                        hyprctl keyword monitor "$name,disable"
                    sleep 1
                    sudo -u "#$uid" \
                        HYPRLAND_INSTANCE_SIGNATURE="$sig" \
                        XDG_RUNTIME_DIR="/run/user/$uid" \
                        hyprctl keyword monitor "$name, $res, $pos, $scale"
                done
            done
        done
        ;;
esac
